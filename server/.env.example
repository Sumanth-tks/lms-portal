# Database Configuration
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# JWT Secrets (Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET="your-secure-random-secret-here-minimum-32-characters"
JWT_REFRESH_SECRET="your-secure-random-refresh-secret-here-minimum-32-characters"

# JWT Token Expiration
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server Configuration
PORT=5001
NODE_ENV="development"

# Client Configuration
CLIENT_URL="http://localhost:3000"

# Database Seeding (Development Only)
# ADMIN_EMAIL="admin@lms.com"
# ADMIN_PASSWORD="your-strong-password-here"
