generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MENTOR
  INTERN
}

enum UserStatus {
  INVITED
  ONBOARDING
  ACTIVE
  PAUSED
  COMPLETED
  CONVERTED
  REMOVED
}

enum BatchStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ContentType {
  VIDEO
  TEXT
  PDF
  CODE
  NOTEBOOK
}

enum AccessEntityType {
  MODULE
  LESSON
  FILE
}

// ─── Core ────────────────────────────────────────────

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  passwordHash    String     @map("password_hash")
  name            String
  role            Role       @default(INTERN)
  avatarUrl       String?    @map("avatar_url")
  status          UserStatus @default(INVITED)
  forcePasswordChange Boolean @default(true) @map("force_password_change")
  batchId         String?    @map("batch_id")
  primaryMentorId String?    @map("primary_mentor_id")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  batch           Batch?     @relation(fields: [batchId], references: [id])
  primaryMentor   User?      @relation("PrimaryMentor", fields: [primaryMentorId], references: [id])
  mentees         User[]     @relation("PrimaryMentor")

  mentorAssignments  MentorIntern[] @relation("MentorSide")
  internAssignments  MentorIntern[] @relation("InternSide")

  createdCourses     Course[]
  createdResources   Resource[]
  accessGrants       InternAccess[] @relation("InternAccessGrants")
  unlockedBy         InternAccess[] @relation("UnlockedByUser")

  refreshTokens      RefreshToken[]
  notifications      Notification[]

  createdModules     Module[]       @relation("ModuleCreator")
  createdLessons     Lesson[]       @relation("LessonCreator")

  datasets           Dataset[]      @relation("DatasetUploader")
  setupCompletions   SetupCompletion[]
  createdChecklists  SetupChecklist[] @relation("ChecklistCreator")

  attendance         Attendance[]   @relation("InternAttendance")
  attendanceOverrides Attendance[]  @relation("AttendanceOverride")
  standups           DailyStandup[] @relation("InternStandups")
  dailyTasks         DailyTask[]    @relation("InternDailyTasks")
  assignedDailyTasks DailyTask[]    @relation("AssignedDailyTasks")

  createdAssignments Assignment[]   @relation("AssignmentCreator")
  submissions        Submission[]   @relation("InternSubmissions")
  gradedSubmissions  Submission[]   @relation("SubmissionGrader")

  createdQuizzes     Quiz[]         @relation("QuizCreator")
  quizAttempts       QuizAttempt[]  @relation("InternQuizAttempts")

  githubLinks        GitHubLink[]   @relation("InternGitHubLinks")
  commits            CommitLog[]    @relation("InternCommits")
  codeReviews        CodeReview[]   @relation("CodeReviewer")

  createdHackathons      Hackathon[]            @relation("HackathonCreator")
  hackathonSubmissions   HackathonSubmission[]  @relation("InternHackathonSubmissions")
  judgedHackathons       HackathonSubmission[]  @relation("HackathonJudge")
  capstoneProject        CapstoneProject?       @relation("InternCapstone")
  mentoredCapstones      CapstoneProject[]      @relation("CapstoneMentor")

  peerReviewsGiven       PeerReview[]           @relation("PeerReviewer")
  peerReviewsReceived    PeerReview[]           @relation("PeerReviewee")
  weeklyReports          WeeklyReport[]         @relation("InternWeeklyReports")
  mentorWeeklyReports    WeeklyReport[]         @relation("MentorWeeklyReports")
  evaluationsReceived    MentorEvaluation[]     @relation("InternEvaluations")
  evaluationsGiven       MentorEvaluation[]     @relation("MentorEvaluations")

  earnedBadges           EarnedBadge[]          @relation("InternBadges")
  xpLogs                 XpLog[]                @relation("InternXpLogs")
  streaks                Streak[]               @relation("InternStreaks")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Batch {
  id        String      @id @default(uuid())
  name      String
  startDate DateTime    @map("start_date")
  endDate   DateTime    @map("end_date")
  status    BatchStatus @default(ACTIVE)
  createdAt DateTime    @default(now()) @map("created_at")

  users       User[]
  hackathons  Hackathon[]

  @@map("batches")
}

model MentorIntern {
  id         String   @id @default(uuid())
  mentorId   String   @map("mentor_id")
  internId   String   @map("intern_id")
  isPrimary  Boolean  @default(false) @map("is_primary")
  assignedAt DateTime @default(now()) @map("assigned_at")

  mentor     User     @relation("MentorSide", fields: [mentorId], references: [id])
  intern     User     @relation("InternSide", fields: [internId], references: [id])

  @@unique([mentorId, internId])
  @@map("mentor_interns")
}

// ─── Curriculum ──────────────────────────────────────

model Course {
  id          String   @id @default(uuid())
  title       String
  description String?
  category    String?
  weekNumber  Int      @map("week_number")
  order       Int      @default(0)
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  creator     User     @relation(fields: [createdBy], references: [id])
  modules     Module[]

  @@map("courses")
}

model Module {
  id                  String   @id @default(uuid())
  courseId             String   @map("course_id")
  title               String
  description         String?
  order               Int      @default(0)
  estimatedDuration   Int?     @map("estimated_duration")
  prerequisiteModuleId String? @map("prerequisite_module_id")
  createdBy           String   @map("created_by")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  course              Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  prerequisite        Module?  @relation("ModulePrerequisite", fields: [prerequisiteModuleId], references: [id])
  dependents          Module[] @relation("ModulePrerequisite")
  lessons             Lesson[]
  resources           Resource[]
  datasets            Dataset[]
  assignments         Assignment[]
  quizzes             Quiz[]
  creator             User     @relation("ModuleCreator", fields: [createdBy], references: [id])

  @@map("modules")
}

model Lesson {
  id          String      @id @default(uuid())
  moduleId    String      @map("module_id")
  title       String
  contentType ContentType @map("content_type")
  content     String?
  fileUrl     String?     @map("file_url")
  duration    Int?
  order       Int         @default(0)
  createdBy   String      @map("created_by")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  module      Module      @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  versions    ContentVersion[]
  creator     User        @relation("LessonCreator", fields: [createdBy], references: [id])

  @@map("lessons")
}

model ContentVersion {
  id        String   @id @default(uuid())
  lessonId  String   @map("lesson_id")
  content   String
  editedBy  String   @map("edited_by")
  createdAt DateTime @default(now()) @map("created_at")

  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("content_versions")
}

model Resource {
  id        String   @id @default(uuid())
  title     String
  url       String
  type      String
  moduleId  String?  @map("module_id")
  shared    Boolean  @default(false)
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  module    Module?  @relation(fields: [moduleId], references: [id])
  creator   User     @relation(fields: [createdBy], references: [id])

  @@map("resources")
}

// ─── Access Control ──────────────────────────────────

model InternAccess {
  id          String           @id @default(uuid())
  internId    String           @map("intern_id")
  entityType  AccessEntityType @map("entity_type")
  entityId    String           @map("entity_id")
  locked      Boolean          @default(true)
  unlockedById String?         @map("unlocked_by")
  unlockedAt  DateTime?        @map("unlocked_at")

  intern      User             @relation("InternAccessGrants", fields: [internId], references: [id])
  unlockedByUser User?         @relation("UnlockedByUser", fields: [unlockedById], references: [id])

  @@unique([internId, entityType, entityId])
  @@map("intern_access")
}

// ─── Datasets ────────────────────────────────────────

model Dataset {
  id          String   @id @default(uuid())
  moduleId    String?  @map("module_id")
  name        String
  description String?
  format      String
  fileUrl     String   @map("file_url")
  sizeBytes   Int?     @map("size_bytes")
  source      String?
  version     String?  @default("1.0")
  uploadedBy  String   @map("uploaded_by")
  createdAt   DateTime @default(now()) @map("created_at")

  module      Module?  @relation(fields: [moduleId], references: [id])
  uploader    User     @relation("DatasetUploader", fields: [uploadedBy], references: [id])

  @@map("datasets")
}

// ─── Setup Guides ────────────────────────────────────

model SetupChecklist {
  id         String   @id @default(uuid())
  weekNumber Int      @map("week_number")
  title      String
  stepsJson  Json     @map("steps_json")
  tools      String
  createdBy  String   @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")

  creator    User     @relation("ChecklistCreator", fields: [createdBy], references: [id])
  completions SetupCompletion[]

  @@map("setup_checklists")
}

model SetupCompletion {
  id          String   @id @default(uuid())
  internId    String   @map("intern_id")
  checklistId String   @map("checklist_id")
  completed   Boolean  @default(false)
  verifiedAt  DateTime? @map("verified_at")

  intern      User     @relation(fields: [internId], references: [id])
  checklist   SetupChecklist @relation(fields: [checklistId], references: [id])

  @@unique([internId, checklistId])
  @@map("setup_completions")
}

// ─── Daily Workflow ──────────────────────────────────

enum AttendanceStatus {
  PRESENT
  LATE
  INCOMPLETE
  ABSENT
  EXCUSED
}

enum DailyTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model Attendance {
  id                  String           @id @default(uuid())
  internId            String           @map("intern_id")
  date                DateTime         @db.Date
  markedAt            DateTime?        @map("marked_at")
  status              AttendanceStatus @default(ABSENT)
  overrideBy          String?          @map("override_by")
  overrideReason      String?          @map("override_reason")
  tasksCompletedCount Int              @default(0) @map("tasks_completed_count")
  tasksTotalCount     Int              @default(0) @map("tasks_total_count")

  intern              User             @relation("InternAttendance", fields: [internId], references: [id])
  overriddenBy        User?            @relation("AttendanceOverride", fields: [overrideBy], references: [id])

  @@unique([internId, date])
  @@map("attendance")
}

model DailyStandup {
  id        String   @id @default(uuid())
  internId  String   @map("intern_id")
  date      DateTime @db.Date
  yesterday String
  today     String
  blockers  String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  intern    User     @relation("InternStandups", fields: [internId], references: [id])

  @@unique([internId, date])
  @@map("daily_standups")
}

model DailyTask {
  id          String          @id @default(uuid())
  internId    String          @map("intern_id")
  date        DateTime        @db.Date
  title       String
  description String?
  assignedBy  String          @map("assigned_by")
  dueTime     DateTime?       @map("due_time")
  status      DailyTaskStatus @default(PENDING)
  completedAt DateTime?       @map("completed_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  intern      User            @relation("InternDailyTasks", fields: [internId], references: [id])
  assigner    User            @relation("AssignedDailyTasks", fields: [assignedBy], references: [id])

  @@map("daily_tasks")
}

// ─── Assignments ─────────────────────────────────────

enum SubmissionStatus {
  SUBMITTED
  GRADED
  RESUBMIT_REQUESTED
}

model Assignment {
  id              String   @id @default(uuid())
  moduleId        String?  @map("module_id")
  title           String
  description     String
  rubricJson      Json?    @map("rubric_json")
  maxScore        Int      @map("max_score")
  deadline        DateTime
  fileTypes       String?  @map("file_types")
  maxFileSize     Int      @default(52428800) @map("max_file_size")
  allowResubmit   Boolean  @default(false) @map("allow_resubmit")
  maxResubmits    Int      @default(1) @map("max_resubmits")
  isMiniProject   Boolean  @default(false) @map("is_mini_project")
  createdBy       String   @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  module          Module?  @relation(fields: [moduleId], references: [id])
  creator         User     @relation("AssignmentCreator", fields: [createdBy], references: [id])
  submissions     Submission[]
  peerReviews     PeerReview[]

  @@map("assignments")
}

model Submission {
  id             String           @id @default(uuid())
  assignmentId   String           @map("assignment_id")
  internId       String           @map("intern_id")
  fileUrl        String?          @map("file_url")
  content        String?
  status         SubmissionStatus @default(SUBMITTED)
  grade          Float?
  feedback       String?
  gradedBy       String?          @map("graded_by")
  gradedAt       DateTime?        @map("graded_at")
  resubmitCount  Int              @default(0) @map("resubmit_count")
  submittedAt    DateTime         @default(now()) @map("submitted_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  assignment     Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  intern         User             @relation("InternSubmissions", fields: [internId], references: [id])
  grader         User?            @relation("SubmissionGrader", fields: [gradedBy], references: [id])

  @@map("submissions")
}

// ─── Quizzes ─────────────────────────────────────────

enum QuizType {
  MCQ
  CODING
  SQL
  CASE_STUDY
}

enum QuestionType {
  MCQ_SINGLE
  MCQ_MULTI
  CODE_PYTHON
  CODE_SQL
  FREE_TEXT
}

enum ScorePolicy {
  BEST
  LAST
}

model Quiz {
  id               String      @id @default(uuid())
  moduleId         String?     @map("module_id")
  title            String
  type             QuizType
  timeLimitMinutes Int?        @map("time_limit_minutes")
  maxRetakes       Int         @default(0) @map("max_retakes")
  scorePolicy      ScorePolicy @default(BEST) @map("score_policy")
  maxScore         Int         @map("max_score")
  weekNumber       Int?        @map("week_number")
  isPublished      Boolean     @default(false) @map("is_published")
  createdBy        String      @map("created_by")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  module           Module?     @relation(fields: [moduleId], references: [id])
  creator          User        @relation("QuizCreator", fields: [createdBy], references: [id])
  questions        QuizQuestion[]
  attempts         QuizAttempt[]

  @@map("quizzes")
}

model QuizQuestion {
  id             String       @id @default(uuid())
  quizId         String       @map("quiz_id")
  questionType   QuestionType @map("question_type")
  question       String
  optionsJson    Json?        @map("options_json")
  correctAnswer  String?      @map("correct_answer")
  testCasesJson  Json?        @map("test_cases_json")
  points         Int
  order          Int          @default(0)
  createdAt      DateTime     @default(now()) @map("created_at")

  quiz           Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_questions")
}

model QuizAttempt {
  id            String   @id @default(uuid())
  quizId        String   @map("quiz_id")
  internId      String   @map("intern_id")
  answersJson   Json     @map("answers_json")
  score         Float?
  maxScore      Int?     @map("max_score")
  attemptNumber Int      @default(1) @map("attempt_number")
  startedAt     DateTime @default(now()) @map("started_at")
  submittedAt   DateTime? @map("submitted_at")

  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  intern        User     @relation("InternQuizAttempts", fields: [internId], references: [id])

  @@map("quiz_attempts")
}

// ─── GitHub & Code ───────────────────────────────────

enum CodeReviewStatus {
  PENDING
  REVIEWED
}

model GitHubLink {
  id         String   @id @default(uuid())
  internId   String   @map("intern_id")
  repoUrl    String   @map("repo_url")
  repoName   String   @map("repo_name")
  linkedAt   DateTime @default(now()) @map("linked_at")

  intern     User     @relation("InternGitHubLinks", fields: [internId], references: [id])
  commits    CommitLog[]

  @@unique([internId, repoUrl])
  @@map("github_links")
}

model CommitLog {
  id             String   @id @default(uuid())
  internId       String   @map("intern_id")
  githubLinkId   String   @map("github_link_id")
  commitHash     String   @map("commit_hash")
  message        String
  filesChanged   Int      @default(0) @map("files_changed")
  additions      Int      @default(0)
  deletions      Int      @default(0)
  date           DateTime

  intern         User       @relation("InternCommits", fields: [internId], references: [id])
  githubLink     GitHubLink @relation(fields: [githubLinkId], references: [id], onDelete: Cascade)
  reviews        CodeReview[]

  @@unique([githubLinkId, commitHash])
  @@map("commit_logs")
}

model CodeReview {
  id            String           @id @default(uuid())
  commitLogId   String           @map("commit_log_id")
  reviewerId    String           @map("reviewer_id")
  commentsJson  Json?            @map("comments_json")
  status        CodeReviewStatus @default(PENDING)
  reviewedAt    DateTime?        @map("reviewed_at")
  createdAt     DateTime         @default(now()) @map("created_at")

  commitLog     CommitLog @relation(fields: [commitLogId], references: [id], onDelete: Cascade)
  reviewer      User      @relation("CodeReviewer", fields: [reviewerId], references: [id])

  @@map("code_reviews")
}

// ─── Hackathons & Capstone ────────────────────────────

enum CapstonePhase {
  STATEMENT
  SOLUTION
  DEPLOYMENT
  DOCUMENTATION
  PRESENTATION
  EVALUATION
}

model Hackathon {
  id              String   @id @default(uuid())
  title           String
  description     String?
  dayNumber       Int      @map("day_number")
  startTime       DateTime @map("start_time")
  endTime         DateTime @map("end_time")
  rubricJson      Json?    @map("rubric_json")
  maxScore        Int      @map("max_score")
  isTeam          Boolean  @default(false) @map("is_team")
  batchId         String?  @map("batch_id")
  createdBy       String   @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  batch           Batch?   @relation(fields: [batchId], references: [id])
  creator         User     @relation("HackathonCreator", fields: [createdBy], references: [id])
  submissions     HackathonSubmission[]

  @@map("hackathons")
}

model HackathonSubmission {
  id            String    @id @default(uuid())
  hackathonId   String    @map("hackathon_id")
  internId      String    @map("intern_id")
  repoUrl       String?   @map("repo_url")
  demoUrl       String?   @map("demo_url")
  submittedAt   DateTime  @default(now()) @map("submitted_at")
  score         Float?
  feedback      String?
  judgedBy      String?   @map("judged_by")

  hackathon     Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  intern        User      @relation("InternHackathonSubmissions", fields: [internId], references: [id])
  judge         User?     @relation("HackathonJudge", fields: [judgedBy], references: [id])

  @@unique([hackathonId, internId])
  @@map("hackathon_submissions")
}

model CapstoneProject {
  id               String        @id @default(uuid())
  internId         String        @map("intern_id")
  mentorId         String?       @map("mentor_id")
  problemStatement String?       @map("problem_statement")
  phase            CapstonePhase @default(STATEMENT)
  repoUrl          String?       @map("repo_url")
  deployedUrl      String?       @map("deployed_url")
  finalScore       Float?        @map("final_score")
  feedbackJson     Json?         @map("feedback_json")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  intern           User          @relation("InternCapstone", fields: [internId], references: [id])
  mentor           User?         @relation("CapstoneMentor", fields: [mentorId], references: [id])

  @@unique([internId])
  @@map("capstone_projects")
}

// ─── Progress & Evaluation ──────────────────────────

enum PeerReviewStatus {
  PENDING
  COMPLETED
}

model PeerReview {
  id            String           @id @default(uuid())
  reviewerId    String           @map("reviewer_id")
  revieweeId    String           @map("reviewee_id")
  assignmentId  String?          @map("assignment_id")
  weekNumber    Int              @map("week_number")
  scoresJson    Json?            @map("scores_json")
  strengths     String?
  improvements  String?
  status        PeerReviewStatus @default(PENDING)
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  reviewer      User             @relation("PeerReviewer", fields: [reviewerId], references: [id])
  reviewee      User             @relation("PeerReviewee", fields: [revieweeId], references: [id])
  assignment    Assignment?      @relation(fields: [assignmentId], references: [id])

  @@unique([reviewerId, revieweeId, weekNumber])
  @@map("peer_reviews")
}

model WeeklyReport {
  id              String   @id @default(uuid())
  internId        String   @map("intern_id")
  mentorId        String?  @map("mentor_id")
  weekNumber      Int      @map("week_number")
  summaryJson     Json     @map("summary_json")
  mentorComments  String?  @map("mentor_comments")
  overallScore    Float?   @map("overall_score")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  intern          User     @relation("InternWeeklyReports", fields: [internId], references: [id])
  mentor          User?    @relation("MentorWeeklyReports", fields: [mentorId], references: [id])

  @@unique([internId, weekNumber])
  @@map("weekly_reports")
}

model MentorEvaluation {
  id              String   @id @default(uuid())
  internId        String   @map("intern_id")
  mentorId        String   @map("mentor_id")
  weekNumber      Int      @map("week_number")
  technicalScore  Float    @map("technical_score")
  softSkillScore  Float    @map("soft_skill_score")
  attendanceScore Float    @map("attendance_score")
  overallScore    Float    @map("overall_score")
  feedback        String?
  areasOfImprovement String? @map("areas_of_improvement")
  createdAt       DateTime @default(now()) @map("created_at")

  intern          User     @relation("InternEvaluations", fields: [internId], references: [id])
  mentor          User     @relation("MentorEvaluations", fields: [mentorId], references: [id])

  @@unique([internId, mentorId, weekNumber])
  @@map("mentor_evaluations")
}

// ─── Gamification ───────────────────────────────────

model Badge {
  id           String   @id @default(uuid())
  name         String   @unique
  description  String
  iconUrl      String?  @map("icon_url")
  category     String
  criteria     String
  xpReward     Int      @default(0) @map("xp_reward")
  createdAt    DateTime @default(now()) @map("created_at")

  earnedBadges EarnedBadge[]

  @@map("badges")
}

model EarnedBadge {
  id        String   @id @default(uuid())
  internId  String   @map("intern_id")
  badgeId   String   @map("badge_id")
  earnedAt  DateTime @default(now()) @map("earned_at")

  intern    User     @relation("InternBadges", fields: [internId], references: [id])
  badge     Badge    @relation(fields: [badgeId], references: [id])

  @@unique([internId, badgeId])
  @@map("earned_badges")
}

model XpLog {
  id        String   @id @default(uuid())
  internId  String   @map("intern_id")
  amount    Int
  reason    String
  sourceType String  @map("source_type")
  sourceId  String?  @map("source_id")
  createdAt DateTime @default(now()) @map("created_at")

  intern    User     @relation("InternXpLogs", fields: [internId], references: [id])

  @@map("xp_logs")
}

model Streak {
  id             String   @id @default(uuid())
  internId       String   @map("intern_id")
  type           String
  currentCount   Int      @default(0) @map("current_count")
  longestCount   Int      @default(0) @map("longest_count")
  lastActivityAt DateTime @default(now()) @map("last_activity_at")

  intern         User     @relation("InternStreaks", fields: [internId], references: [id])

  @@unique([internId, type])
  @@map("streaks")
}

// ─── Notifications ───────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id])

  @@map("notifications")
}
